# Broccers — fichier d'exemple d'environnement
# Copier ce fichier en .env et remplir les valeurs.
# .env est ignoré par Git pour ne pas exposer les secrets.

# === Authentification ===
# Hash bcrypt du PIN super-admin. Généré via :
#   dart run scripts/setup-pin.dart 1234
# Puis copier la sortie BR_PIN_BCRYPT_HASH ci-dessous.
BR_PIN_BCRYPT_HASH=

# Secret JWT (HS256). Si vide, un secret éphémère est généré au démarrage,
# mais sera perdu au redémarrage (les sessions seront invalidées).
# Pour la prod, générer une fois et conserver.
BR_JWT_SECRET=

# === IA Claude (subprocess) ===
# Chemin vers le binaire claude CLI (Claude Max abonnement).
# Sous Linux/Docker, à monter en volume ou installer dans l'image.
# Par défaut /usr/local/bin/claude
BR_CLAUDE_CLI_PATH=/usr/local/bin/claude

# === Whisper STT (optionnel) ===
# URL du serveur Whisper hébergé sur Titan (cluster Tailscale).
# Si vide, fallback mode texte uniquement pour la commande vocale.
# Exemple : http://titan.tailnet.ts.net:9000
BR_WHISPER_URL=
